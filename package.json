    "fuzzball": "^2.2.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@neutralinojs/neu": "^11.7.2",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.2"
  }
